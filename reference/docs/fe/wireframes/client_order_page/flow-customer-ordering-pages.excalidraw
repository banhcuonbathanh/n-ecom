{"id":"g5txt","type":"text","x":924,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6020,"version":1,"versionNonce":6020,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"fO","link":null,"locked":false,"frameId":null,"text":"FILE\n(shop)/order/[id]/page.tsx\n\nHOOK\nuseOrderSSE(params.id)\n→ order, progress (0–100)\n→ connectionError, notification\n\nSSE EVENTS\norder_init   (on connect)\nitem_progress → dot colors\norder_status_changed → badge\norder_completed → 100%\nkeep-alive   (15s ping)\n\nRECONNECT\nmax 5 attempts\nexp backoff 1s → 30s\n\nCANCEL ACTIONS\nDELETE /orders/{id}\nDELETE /orders/items/{itemId}","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"FILE\n(shop)/order/[id]/page.tsx\n\nHOOK\nuseOrderSSE(params.id)\n→ order, progress (0–100)\n→ connectionError, notification\n\nSSE EVENTS\norder_init   (on connect)\nitem_progress → dot colors\norder_status_changed → badge\norder_completed → 100%\nkeep-alive   (15s ping)\n\nRECONNECT\nmax 5 attempts\nexp backoff 1s → 30s\n\nCANCEL ACTIONS\nDELETE /orders/{id}\nDELETE /orders/items/{itemId}","lineHeight":1.35,"autoResize":false}

