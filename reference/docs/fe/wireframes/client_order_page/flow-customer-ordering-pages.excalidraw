{"id":"g1txt","type":"text","x":204,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6008,"version":1,"versionNonce":6008,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"fC","link":null,"locked":false,"frameId":null,"text":"FILE\n(shop)/menu/page.tsx\n\nCOMPONENTS\nCategoryTabs   → tab filter\nProductCard    → list rows\nComboCard      → combo rows\nCartDrawer     → slide-up cart\nEmptyState     → no results\n\nQUERIES (TanStack, stale 5min)\n['categories']\n['products', selectedCategory]\n['combos']\n\nSTATE\nuseCartStore: itemCount, total\nuseSettingsStore: tableLabel","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"FILE\n(shop)/menu/page.tsx\n\nCOMPONENTS\nCategoryTabs   → tab filter\nProductCard    → list rows\nComboCard      → combo rows\nCartDrawer     → slide-up cart\nEmptyState     → no results\n\nQUERIES (TanStack, stale 5min)\n['categories']\n['products', selectedCategory]\n['combos']\n\nSTATE\nuseCartStore: itemCount, total\nuseSettingsStore: tableLabel","lineHeight":1.35,"autoResize":false},

