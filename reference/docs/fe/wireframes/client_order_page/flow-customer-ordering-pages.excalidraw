{"id":"g0txt","type":"text","x":24,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6005,"version":1,"versionNonce":6005,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"f9","link":null,"locked":false,"frameId":null,"text":"FILE\n(shop)/table/[tableId]/page.tsx\n\nFLOW\n1. POST /auth/guest {qr_token}\n2. setAuth(guestUser, token)\n   setTableId(table.id)\n3. router.replace('/menu')\n\nERROR PATHS\n· TABLE_HAS_ACTIVE_ORDER\n  → /order/{active_order_id}\n· invalid token → error msg\n\nSTATE\nuseAuthStore · useCartStore\n\nNO UI — spinner only","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"FILE\n(shop)/table/[tableId]/page.tsx\n\nFLOW\n1. POST /auth/guest {qr_token}\n2. setAuth(guestUser, token)\n   setTableId(table.id)\n3. router.replace('/menu')\n\nERROR PATHS\n· TABLE_HAS_ACTIVE_ORDER\n  → /order/{active_order_id}\n· invalid token → error msg\n\nSTATE\nuseAuthStore · useCartStore\n\nNO UI — spinner only","lineHeight":1.35,"autoResize":false},

