{"id":"g3txt","type":"text","x":564,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6014,"version":1,"versionNonce":6014,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"fI","link":null,"locked":false,"frameId":null,"text":"FILE\n(shop)/checkout/page.tsx\n\nFORM (RHF + Zod schema)\ncustomer_name  min(2) max(100)\ncustomer_phone regex 0[0-9]{9}\nnote?          max(500)\npayment_method vnpay|momo|\n               zalopay|cash\n\nPOST /orders body\n{ customer_name, customer_phone,\n  note, table_id,\n  source: 'qr' | 'online',\n  items[]: product_id|combo_id,\n  qty, unit_price,\n  topping_snapshot }\n\nGUARD: itemCount===0 → /menu","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"FILE\n(shop)/checkout/page.tsx\n\nFORM (RHF + Zod schema)\ncustomer_name  min(2) max(100)\ncustomer_phone regex 0[0-9]{9}\nnote?          max(500)\npayment_method vnpay|momo|\n               zalopay|cash\n\nPOST /orders body\n{ customer_name, customer_phone,\n  note, table_id,\n  source: 'qr' | 'online',\n  items[]: product_id|combo_id,\n  qty, unit_price,\n  topping_snapshot }\n\nGUARD: itemCount===0 → /menu","lineHeight":1.35,"autoResize":false},

