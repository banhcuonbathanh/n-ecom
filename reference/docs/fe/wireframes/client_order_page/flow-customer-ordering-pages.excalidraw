{"id":"g4txt","type":"text","x":744,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6017,"version":1,"versionNonce":6017,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"fL","link":null,"locked":false,"frameId":null,"text":"MUTATION STATE\nsubmitOrder.isPending = true\nButton: disabled + 'Đang đặt...'\n\nON SUCCESS (201)\n1. cart.clearCart()\n2. window.location.replace\n   ('/order')\n   (hard redirect, not router)\n\nON ERROR\n· 409 TABLE_HAS_ACTIVE_ORDER\n  → router.push('/order')\n· other → toast.error(message)\n\nNOTE\npayment_method stored in\ncartStore, NOT in POST body\n(spec AC-08)","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"MUTATION STATE\nsubmitOrder.isPending = true\nButton: disabled + 'Đang đặt...'\n\nON SUCCESS (201)\n1. cart.clearCart()\n2. window.location.replace\n   ('/order')\n   (hard redirect, not router)\n\nON ERROR\n· 409 TABLE_HAS_ACTIVE_ORDER\n  → router.push('/order')\n· other → toast.error(message)\n\nNOTE\npayment_method stored in\ncartStore, NOT in POST body\n(spec AC-08)","lineHeight":1.35,"autoResize":false},

