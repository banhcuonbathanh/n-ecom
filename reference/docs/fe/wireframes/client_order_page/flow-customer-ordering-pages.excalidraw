{"id":"g2txt","type":"text","x":384,"y":479,"width":152,"height":200,"angle":0,"strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6011,"version":1,"versionNonce":6011,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"fF","link":null,"locked":false,"frameId":null,"text":"CartDrawer\ncomponents/menu/CartDrawer.tsx\nOpens: setCartOpen(true) from FAB\n\nADD ITEM MODALS\n· has_toppings → ToppingModal\n· is_combo     → ComboModal\n· simple       → addItem direct\n\ncartStore.addItem({\n  product_id, qty,\n  unit_price,\n  topping_snapshot\n})\n\nCART → CHECKOUT\n'Xác nhận đơn hàng'\n→ router.push('/checkout')","fontSize":7,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CartDrawer\ncomponents/menu/CartDrawer.tsx\nOpens: setCartOpen(true) from FAB\n\nADD ITEM MODALS\n· has_toppings → ToppingModal\n· is_combo     → ComboModal\n· simple       → addItem direct\n\ncartStore.addItem({\n  product_id, qty,\n  unit_price,\n  topping_snapshot\n})\n\nCART → CHECKOUT\n'Xác nhận đơn hàng'\n→ router.push('/checkout')","lineHeight":1.35,"autoResize":false},

