{"id":"note004","type":"text","x":2324,"y":1030,"width":432,"height":110,"angle":0,"strokeColor":"#166534","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":7021,"version":1,"versionNonce":7021,"isDeleted":false,"boundElements":[],"updated":1747440000000,"index":"cI","link":null,"locked":false,"frameId":null,"text":"P11 — ADD ITEMS TO EXISTING ORDER (IN PROGRESS)\n\n• From /order/[id]: 'Thêm món' button\n  (visible if status ∈ pending/confirmed/preparing)\n• Push to /menu?add_to_order={orderId}\n• On submit → POST /orders/:id/items (not new order)\n• SSE items_added event → KDS sees new items","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"P11 — ADD ITEMS TO EXISTING ORDER (IN PROGRESS)\n\n• From /order/[id]: 'Thêm món' button\n  (visible if status ∈ pending/confirmed/preparing)\n• Push to /menu?add_to_order={orderId}\n• On submit → POST /orders/:id/items (not new order)\n• SSE items_added event → KDS sees new items","lineHeight":1.35,"autoResize":false}
