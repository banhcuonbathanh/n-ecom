    {"id":"b_tasks_t","type":"text","x":2027,"y":2137,"width":550,"height":356,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":371,"version":1,"versionNonce":371,"isDeleted":false,"boundElements":[],"updated":1746400000000,"index":"c5","link":null,"locked":false,"frameId":null,"text":"docs/TASKS.md вЂ” Task Rows\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nBE task row format:\n| ID | Domain | Task | Status |\n\nFE task row format (v1.1):\n| ID | Domain | Task | Status\n  | spec_ref | draw_ref |\n\n spec_ref: exact spec section\n   e.g. Spec_9 В§3.2\n draw_ref: wireframe file + zone\n   e.g. wireframes/overview.md zone-B\n\nTask must NOT start if:\n  в†’ spec_ref missing (FE)\n  в†’ draw_ref missing (FE)\n  в†’ dep not вњ…\n  в†’ рџ”ґ BLOCKED note\n\nStatus lifecycle:\n  в¬њ not started\n  рџ”„ in progress\n  вњ… done\n  рџ”ґ blocked","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/TASKS.md вЂ” Task Rows\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nBE task row format:\n| ID | Domain | Task | Status |\n\nFE task row format (v1.1):\n| ID | Domain | Task | Status\n  | spec_ref | draw_ref |\n\n spec_ref: exact spec section\n   e.g. Spec_9 В§3.2\n draw_ref: wireframe file + zone\n   e.g. wireframes/overview.md zone-B\n\nTask must NOT start if:\n  в†’ spec_ref missing (FE)\n  в†’ draw_ref missing (FE)\n  в†’ dep not вњ…\n  в†’ рџ”ґ BLOCKED note\n\nStatus lifecycle:\n  в¬њ not started\n  рџ”„ in progress\n  вњ… done\n  рџ”ґ blocked","lineHeight":1.35,"autoResize":false},

