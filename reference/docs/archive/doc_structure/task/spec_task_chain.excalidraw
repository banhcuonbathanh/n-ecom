    {"id":"brd_hdr_t","type":"text","x":65,"y":121,"width":970,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":11,"version":1,"versionNonce":11,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"a8","link":null,"locked":false,"frameId":null,"text":"BRD — Business Requirements Document\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHY are we building this?\nWHO are the users?\nWHAT is in Phase 1 scope?","fontSize":15,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"BRD — Business Requirements Document\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHY are we building this?\nWHO are the users?\nWHAT is in Phase 1 scope?","lineHeight":1.35,"autoResize":false},

    {"id":"brd_q_r","type":"rectangle","x":50,"y":248,"width":1000,"height":95,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#ede9fe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":12,"version":1,"versionNonce":12,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"a9","link":null,"locked":false,"frameId":null},
    {"id":"brd_q_t","type":"text","x":65,"y":256,"width":970,"height":80,"angle":0,"strokeColor":"#3b0764","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":13,"version":1,"versionNonce":13,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aA","link":null,"locked":false,"frameId":null,"text":"SCOPE GATE — Produces 2 things used by every level below:\n  1. Role hierarchy (6 roles → RBAC in every spec endpoint table)\n  2. Phase scope table (feature → Phase 1/2/3 → write spec or not)","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"SCOPE GATE — Produces 2 things used by every level below:\n  1. Role hierarchy (6 roles → RBAC in every spec endpoint table)\n  2. Phase scope table (feature → Phase 1/2/3 → write spec or not)","lineHeight":1.35,"autoResize":false},

    {"id":"brd_c_r","type":"rectangle","x":50,"y":351,"width":1000,"height":340,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#f3e8ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":14,"version":1,"versionNonce":14,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aB","link":null,"locked":false,"frameId":null},
    {"id":"brd_c_t","type":"text","x":65,"y":360,"width":970,"height":324,"angle":0,"strokeColor":"#3b0764","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":15,"version":1,"versionNonce":15,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aC","link":null,"locked":false,"frameId":null,"text":"CONTAINS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nExecutive Summary\n  → business problem, proposed solution\n\nStakeholders & User Personas (RBAC origin)\n  admin > manager > staff > (chef|cashier) > customer\n  each role: devices used, permissions, concern\n\nProject Scope Table  ← THE SCOPE GATE\n  feature | phase | status\n  QR Table Ordering → Phase 1 → Spec_6 gets written\n  Quan Ly Kho       → Phase 2 → no spec, no task yet\n  Computer Vision   → Phase 3 → completely out of scope\n\nConstraints (bound all technical decisions)\n  → Next.js, Go, MySQL, Redis, Docker, Caddy\n  → VNPay, MoMo, ZaloPay payment gateways\n  → VPS deployment (not cloud)\n\nSuccess Criteria\n  → API response <500ms p95\n  → 1000 concurrent users no degradation","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CONTAINS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nExecutive Summary\n  → business problem, proposed solution\n\nStakeholders & User Personas (RBAC origin)\n  admin > manager > staff > (chef|cashier) > customer\n  each role: devices used, permissions, concern\n\nProject Scope Table  ← THE SCOPE GATE\n  feature | phase | status\n  QR Table Ordering → Phase 1 → Spec_6 gets written\n  Quan Ly Kho       → Phase 2 → no spec, no task yet\n  Computer Vision   → Phase 3 → completely out of scope\n\nConstraints (bound all technical decisions)\n  → Next.js, Go, MySQL, Redis, Docker, Caddy\n  → VNPay, MoMo, ZaloPay payment gateways\n  → VPS deployment (not cloud)\n\nSuccess Criteria\n  → API response <500ms p95\n  → 1000 concurrent users no degradation","lineHeight":1.35,"autoResize":false},

    {"id":"brd_e_r","type":"rectangle","x":50,"y":699,"width":1000,"height":230,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#f3e8ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":16,"version":1,"versionNonce":16,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aD","link":null,"locked":false,"frameId":null},
    {"id":"brd_e_t","type":"text","x":65,"y":707,"width":970,"height":214,"angle":0,"strokeColor":"#3b0764","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":17,"version":1,"versionNonce":17,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aE","link":null,"locked":false,"frameId":null,"text":"REAL EXAMPLE — BRD §2.2 + §1.3:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nRole table → becomes RBAC column in every spec:\n  cashier → POST /orders (tạo đơn POS)\n  chef    → PATCH /orders/:id/items/:itemId/status\n  customer → GET /orders/:id (own orders only)\n\nScope gate in action:\n  BRD §1.3 says 'Quan Ly Kho → Phase 2'\n  → NO spec written for inventory\n  → NO inventory task in TASKS.md\n  → IF dev adds inventory code → scope creep\n     → 🔴 STOP, remove it","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"REAL EXAMPLE — BRD §2.2 + §1.3:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nRole table → becomes RBAC column in every spec:\n  cashier → POST /orders (tạo đơn POS)\n  chef    → PATCH /orders/:id/items/:itemId/status\n  customer → GET /orders/:id (own orders only)\n\nScope gate in action:\n  BRD §1.3 says 'Quan Ly Kho → Phase 2'\n  → NO spec written for inventory\n  → NO inventory task in TASKS.md\n  → IF dev adds inventory code → scope creep\n     → 🔴 STOP, remove it","lineHeight":1.35,"autoResize":false},

    {"id":"brd_prin_r","type":"rectangle","x":50,"y":937,"width":1000,"height":118,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#6d28d9","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":18,"version":1,"versionNonce":18,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aF","link":null,"locked":false,"frameId":null},
    {"id":"brd_prin_t","type":"text","x":65,"y":945,"width":970,"height":102,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":19,"version":1,"versionNonce":19,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aG","link":null,"locked":false,"frameId":null,"text":"PRINCIPLE — SCOPE GATE:\nDo NOT write a spec or task for anything not in BRD Phase 1 scope.\nThe BRD is the only document that decides what gets built.\nA task without a BRD scope entry = someone invented a feature.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PRINCIPLE — SCOPE GATE:\nDo NOT write a spec or task for anything not in BRD Phase 1 scope.\nThe BRD is the only document that decides what gets built.\nA task without a BRD scope entry = someone invented a feature.","lineHeight":1.35,"autoResize":false},

    {"id":"srs_hdr_r","type":"rectangle","x":1115,"y":112,"width":1000,"height":128,"angle":0,"strokeColor":"#1d4ed8","backgroundColor":"#1d4ed8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":20,"version":1,"versionNonce":20,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aH","link":null,"locked":false,"frameId":null},
    {"id":"srs_hdr_t","type":"text","x":1130,"y":121,"width":970,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":21,"version":1,"versionNonce":21,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aI","link":null,"locked":false,"frameId":null,"text":"SRS / FSD — System Requirements Specification\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHAT must the system do, step by step?\nUnder what conditions? Verified how?","fontSize":15,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"SRS / FSD — System Requirements Specification\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHAT must the system do, step by step?\nUnder what conditions? Verified how?","lineHeight":1.35,"autoResize":false},

    {"id":"srs_q_r","type":"rectangle","x":1115,"y":248,"width":1000,"height":95,"angle":0,"strokeColor":"#1d4ed8","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":22,"version":1,"versionNonce":22,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aJ","link":null,"locked":false,"frameId":null},
    {"id":"srs_q_t","type":"text","x":1130,"y":256,"width":970,"height":80,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":23,"version":1,"versionNonce":23,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aK","link":null,"locked":false,"frameId":null,"text":"RULE GATE — Produces 3 things that flow into every spec:\n  1. Numbered business rules (BR-001+) → spec validations\n  2. Acceptance criteria per feature → task 'done' definition\n  3. NFR thresholds → implementation constraints (no separate tasks)","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"RULE GATE — Produces 3 things that flow into every spec:\n  1. Numbered business rules (BR-001+) → spec validations\n  2. Acceptance criteria per feature → task 'done' definition\n  3. NFR thresholds → implementation constraints (no separate tasks)","lineHeight":1.35,"autoResize":false},

    {"id":"srs_c_r","type":"rectangle","x":1115,"y":351,"width":1000,"height":340,"angle":0,"strokeColor":"#1d4ed8","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":24,"version":1,"versionNonce":24,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aL","link":null,"locked":false,"frameId":null},
    {"id":"srs_c_t","type":"text","x":1130,"y":360,"width":970,"height":324,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":25,"version":1,"versionNonce":25,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aM","link":null,"locked":false,"frameId":null,"text":"CONTAINS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nFeature Modules (detailed behavior per module)\n  Customer Portal · KDS · POS · Auth · Dashboard\n\nBusiness Rules (numbered, precise, complete)\n  BR-001: 1 table → max 1 ACTIVE order → 409 Conflict\n  BR-002: cancel only if SUM(qty_served)/SUM(qty) < 30%\n  BR-003: HMAC must be verified BEFORE reading any webhook field\n  BR-004: recalculateTotalAmount() after every order_items mutation\n  BR-005: access token = 15m · refresh token = 7d httpOnly\n\nAcceptance Criteria per feature (testable conditions)\n  'cancel order: reject if ≥30% served, same error for customer + cashier'\n\nNon-Functional Requirements (NFR) — constraints, not tasks\n  → API response <500ms p95 · page load <3s LCP\n  → bcrypt cost=12 · HTTPS only · no SQL injection\n  → 1000 concurrent users · RTO <4h for recovery\n\nUser Flows (step-by-step interactions)\n  → QR scan → table page → select items → checkout → track","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CONTAINS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nFeature Modules (detailed behavior per module)\n  Customer Portal · KDS · POS · Auth · Dashboard\n\nBusiness Rules (numbered, precise, complete)\n  BR-001: 1 table → max 1 ACTIVE order → 409 Conflict\n  BR-002: cancel only if SUM(qty_served)/SUM(qty) < 30%\n  BR-003: HMAC must be verified BEFORE reading any webhook field\n  BR-004: recalculateTotalAmount() after every order_items mutation\n  BR-005: access token = 15m · refresh token = 7d httpOnly\n\nAcceptance Criteria per feature (testable conditions)\n  'cancel order: reject if ≥30% served, same error for customer + cashier'\n\nNon-Functional Requirements (NFR) — constraints, not tasks\n  → API response <500ms p95 · page load <3s LCP\n  → bcrypt cost=12 · HTTPS only · no SQL injection\n  → 1000 concurrent users · RTO <4h for recovery\n\nUser Flows (step-by-step interactions)\n  → QR scan → table page → select items → checkout → track","lineHeight":1.35,"autoResize":false},

    {"id":"srs_e_r","type":"rectangle","x":1115,"y":699,"width":1000,"height":230,"angle":0,"strokeColor":"#1d4ed8","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":26,"version":1,"versionNonce":26,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aN","link":null,"locked":false,"frameId":null},
    {"id":"srs_e_t","type":"text","x":1130,"y":707,"width":970,"height":214,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":27,"version":1,"versionNonce":27,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aO","link":null,"locked":false,"frameId":null,"text":"HOW SRS RULES FLOW INTO SPECS + TASKS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nBR-001 (1 table 1 ACTIVE order) →\n  Spec_4 §5.1: 'table_id: check no ACTIVE order → 409'\n  Task 4-1: validation in CreateOrder service\n  Step 6 TEST: test case 'create 2nd order same table = 409'\n\nBR-002 (cancel <30% rule) →\n  Spec_4 §5.1: DELETE /orders/:id validation rule\n  Task 4-4: CancelOrder with 30% guard (separate task)\n  Step 5 SELF-REVIEW: 'cancel 30% check ✓'\n\nNFR 'API <500ms' → NOT a task\n  → constraint: use Redis caching, avoid N+1 queries\n  → checked in Step 6 load test (if applicable)","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"HOW SRS RULES FLOW INTO SPECS + TASKS:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nBR-001 (1 table 1 ACTIVE order) →\n  Spec_4 §5.1: 'table_id: check no ACTIVE order → 409'\n  Task 4-1: validation in CreateOrder service\n  Step 6 TEST: test case 'create 2nd order same table = 409'\n\nBR-002 (cancel <30% rule) →\n  Spec_4 §5.1: DELETE /orders/:id validation rule\n  Task 4-4: CancelOrder with 30% guard (separate task)\n  Step 5 SELF-REVIEW: 'cancel 30% check ✓'\n\nNFR 'API <500ms' → NOT a task\n  → constraint: use Redis caching, avoid N+1 queries\n  → checked in Step 6 load test (if applicable)","lineHeight":1.35,"autoResize":false},

    {"id":"srs_prin_r","type":"rectangle","x":1115,"y":937,"width":1000,"height":118,"angle":0,"strokeColor":"#1d4ed8","backgroundColor":"#1d4ed8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":28,"version":1,"versionNonce":28,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aP","link":null,"locked":false,"frameId":null},
    {"id":"srs_prin_t","type":"text","x":1130,"y":945,"width":970,"height":102,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":29,"version":1,"versionNonce":29,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aQ","link":null,"locked":false,"frameId":null,"text":"PRINCIPLE — RULE GATE:\nEvery feature MUST have numbered business rules + AC before a spec section is written.\nMissing rules → spec author guesses → developer guesses → production bug.\nNFR thresholds are implementation constraints, NOT task rows.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PRINCIPLE — RULE GATE:\nEvery feature MUST have numbered business rules + AC before a spec section is written.\nMissing rules → spec author guesses → developer guesses → production bug.\nNFR thresholds are implementation constraints, NOT task rows.","lineHeight":1.35,"autoResize":false},

    {"id":"spec_hdr_r","type":"rectangle","x":2180,"y":112,"width":1000,"height":128,"angle":0,"strokeColor":"#15803d","backgroundColor":"#15803d","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":30,"version":1,"versionNonce":30,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aR","link":null,"locked":false,"frameId":null},
    {"id":"spec_hdr_t","type":"text","x":2195,"y":121,"width":970,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":31,"version":1,"versionNonce":31,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aS","link":null,"locked":false,"frameId":null,"text":"Spec 1-9 — Domain Implementation Spec\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nHOW does this endpoint / component / flow work precisely?\nWhat inputs, outputs, validations, side effects?","fontSize":15,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Spec 1-9 — Domain Implementation Spec\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nHOW does this endpoint / component / flow work precisely?\nWhat inputs, outputs, validations, side effects?","lineHeight":1.35,"autoResize":false},

    {"id":"spec_q_r","type":"rectangle","x":2180,"y":248,"width":1000,"height":95,"angle":0,"strokeColor":"#15803d","backgroundColor":"#dcfce7","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":32,"version":1,"versionNonce":32,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aT","link":null,"locked":false,"frameId":null},
    {"id":"spec_q_t","type":"text","x":2195,"y":256,"width":970,"height":80,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":33,"version":1,"versionNonce":33,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aU","link":null,"locked":false,"frameId":null,"text":"CONTRACT GATE — A spec section is complete ONLY when:\n  Developer reads ONLY this section + DB_SCHEMA + ERROR_CONTRACT\n  and can implement it with ZERO guessing about fields, rules, or shapes.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CONTRACT GATE — A spec section is complete ONLY when:\n  Developer reads ONLY this section + DB_SCHEMA + ERROR_CONTRACT\n  and can implement it with ZERO guessing about fields, rules, or shapes.","lineHeight":1.35,"autoResize":false},

    {"id":"spec_c_r","type":"rectangle","x":2180,"y":351,"width":1000,"height":340,"angle":0,"strokeColor":"#15803d","backgroundColor":"#f0fdf4","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":34,"version":1,"versionNonce":34,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aV","link":null,"locked":false,"frameId":null},
    {"id":"spec_c_t","type":"text","x":2195,"y":360,"width":970,"height":324,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":35,"version":1,"versionNonce":35,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aW","link":null,"locked":false,"frameId":null,"text":"A SPEC SECTION MUST CONTAIN ALL OF THESE:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEndpoint table\n  method · path · role · description\n  e.g. PATCH /api/v1/orders/:id/items/:itemId/status · Chef+\n\nState machine (if stateful)\n  transitions + who triggers + conditions per transition\n  e.g. pending→confirmed→preparing→ready→delivered\n\nRequest / Response shapes\n  exact field names + types + nullability\n  e.g. { product_id: int|null, quantity: int, unit_price: decimal }\n\nValidation rules (each one linked to a BR-xxx)\n  e.g. 'table_id: check no ACTIVE order → 409' (from BR-001)\n\nSide effects — ALL listed explicitly\n  e.g. recalculateTotalAmount() · WS broadcast · Redis pub/sub\n\nOut-of-scope boundary (prevent drift)\n  e.g. 'Payment → Spec_5. Inventory → future phase'","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"A SPEC SECTION MUST CONTAIN ALL OF THESE:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEndpoint table\n  method · path · role · description\n  e.g. PATCH /api/v1/orders/:id/items/:itemId/status · Chef+\n\nState machine (if stateful)\n  transitions + who triggers + conditions per transition\n  e.g. pending→confirmed→preparing→ready→delivered\n\nRequest / Response shapes\n  exact field names + types + nullability\n  e.g. { product_id: int|null, quantity: int, unit_price: decimal }\n\nValidation rules (each one linked to a BR-xxx)\n  e.g. 'table_id: check no ACTIVE order → 409' (from BR-001)\n\nSide effects — ALL listed explicitly\n  e.g. recalculateTotalAmount() · WS broadcast · Redis pub/sub\n\nOut-of-scope boundary (prevent drift)\n  e.g. 'Payment → Spec_5. Inventory → future phase'","lineHeight":1.35,"autoResize":false},

    {"id":"spec_e_r","type":"rectangle","x":2180,"y":699,"width":1000,"height":230,"angle":0,"strokeColor":"#15803d","backgroundColor":"#f0fdf4","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":36,"version":1,"versionNonce":36,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aX","link":null,"locked":false,"frameId":null},
    {"id":"spec_e_t","type":"text","x":2195,"y":707,"width":970,"height":214,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":37,"version":1,"versionNonce":37,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aY","link":null,"locked":false,"frameId":null,"text":"REAL EXAMPLE — Spec_4 §5.2 (one section):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEndpoint: PATCH /api/v1/orders/:id/items/:itemId/status\nRole: Chef+\nBehavior: cycle item status pending→preparing→done\nValidation: item must belong to order_id\nSide effects (ALL listed):\n  → recalculateTotalAmount() REQUIRED after status change\n  → WS broadcast to /ws/kitchen (all chefs see update)\n  → WS broadcast to /ws/orders-live (cashier grid updates)\n  → if all items done → trigger order status → 'ready' (auto)\nOut of scope: payment (→ Spec_5), inventory deduction (→ Phase 2)\n\nWhy separate from cancel endpoint? Different BR, different role, different side effect.","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"REAL EXAMPLE — Spec_4 §5.2 (one section):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEndpoint: PATCH /api/v1/orders/:id/items/:itemId/status\nRole: Chef+\nBehavior: cycle item status pending→preparing→done\nValidation: item must belong to order_id\nSide effects (ALL listed):\n  → recalculateTotalAmount() REQUIRED after status change\n  → WS broadcast to /ws/kitchen (all chefs see update)\n  → WS broadcast to /ws/orders-live (cashier grid updates)\n  → if all items done → trigger order status → 'ready' (auto)\nOut of scope: payment (→ Spec_5), inventory deduction (→ Phase 2)\n\nWhy separate from cancel endpoint? Different BR, different role, different side effect.","lineHeight":1.35,"autoResize":false},

    {"id":"spec_prin_r","type":"rectangle","x":2180,"y":937,"width":1000,"height":118,"angle":0,"strokeColor":"#15803d","backgroundColor":"#15803d","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":38,"version":1,"versionNonce":38,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"aZ","link":null,"locked":false,"frameId":null},
    {"id":"spec_prin_t","type":"text","x":2195,"y":945,"width":970,"height":102,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":39,"version":1,"versionNonce":39,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b0","link":null,"locked":false,"frameId":null,"text":"PRINCIPLE — CONTRACT GATE:\nIf any field type, validation condition, or state transition is unclear → spec is INCOMPLETE.\nAction: flag ❓ CLARIFY, do NOT guess and proceed.\nA spec section is one spec when it has one out-of-scope boundary statement.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PRINCIPLE — CONTRACT GATE:\nIf any field type, validation condition, or state transition is unclear → spec is INCOMPLETE.\nAction: flag ❓ CLARIFY, do NOT guess and proceed.\nA spec section is one spec when it has one out-of-scope boundary statement.","lineHeight":1.35,"autoResize":false},

