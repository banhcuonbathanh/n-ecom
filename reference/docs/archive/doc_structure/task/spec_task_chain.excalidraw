    {"id":"sep_t","type":"text","x":20,"y":1072,"width":4700,"height":18,"angle":0,"strokeColor":"#f8fafc","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":71,"version":1,"versionNonce":71,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"bI","link":null,"locked":false,"frameId":null,"text":"PHẦN 2 — THE TRACEABILITY PRINCIPLE  ·  Every task must trace backward through all 4 levels  ·  Break in chain = wrong thing built","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PHẦN 2 — THE TRACEABILITY PRINCIPLE  ·  Every task must trace backward through all 4 levels  ·  Break in chain = wrong thing built","lineHeight":1.35,"autoResize":true},

