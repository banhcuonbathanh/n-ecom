    {"id":"task_hdr_t","type":"text","x":3260,"y":121,"width":1430,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":41,"version":1,"versionNonce":41,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b2","link":null,"locked":false,"frameId":null,"text":"Task Rows — docs/TASKS.md\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHAT is the smallest unit I can implement AND verify\nindependently, without needing other tasks to complete first?","fontSize":15,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Task Rows — docs/TASKS.md\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nQuestion it answers:\nWHAT is the smallest unit I can implement AND verify\nindependently, without needing other tasks to complete first?","lineHeight":1.35,"autoResize":false},

    {"id":"task_q_r","type":"rectangle","x":3245,"y":248,"width":1460,"height":95,"angle":0,"strokeColor":"#ea580c","backgroundColor":"#fff7ed","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":42,"version":1,"versionNonce":42,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b3","link":null,"locked":false,"frameId":null},
    {"id":"task_q_t","type":"text","x":3260,"y":256,"width":1430,"height":80,"angle":0,"strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":43,"version":1,"versionNonce":43,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b4","link":null,"locked":false,"frameId":null,"text":"BOUNDARY RULE — One task = one independently verifiable unit:\n  Can I run go build ./... (or npm run build) and prove THIS task works alone?\n  If yes → one task. If no → split it or it has an unresolved dependency.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"BOUNDARY RULE — One task = one independently verifiable unit:\n  Can I run go build ./... (or npm run build) and prove THIS task works alone?\n  If yes → one task. If no → split it or it has an unresolved dependency.","lineHeight":1.35,"autoResize":false},

    {"id":"task_c_r","type":"rectangle","x":3245,"y":351,"width":1460,"height":340,"angle":0,"strokeColor":"#ea580c","backgroundColor":"#fff7ed","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":44,"version":1,"versionNonce":44,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b5","link":null,"locked":false,"frameId":null},
    {"id":"task_c_t","type":"text","x":3260,"y":360,"width":1430,"height":324,"angle":0,"strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":45,"version":1,"versionNonce":45,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b6","link":null,"locked":false,"frameId":null,"text":"SPLIT SIGNAL — These always create a NEW task row:\n  Different business rule → different test case → different task\n    e.g. CreateOrder (BR-001 1-table-1-active) ≠ CancelOrder (BR-002 30% rule)\n  Different protocol → different implementation pattern → different task\n    e.g. SSE stream ≠ WebSocket hub (different connection lifecycle)\n  Mandatory side effect → must be verified alone → different task\n    e.g. KDS item update requires recalculateTotalAmount() + WS broadcast\n\nFE EXTRA GATE — Step 0 before any task rows:\n  0a READ SPEC end-to-end (mark screens, components, data sources)\n  0b DRAW Wireframe (label zones [ComponentName] + data source per zone)\n      ┌─────────────────────┬────────────────────┐\n      │ [OrderList]         │ [PrepPanel]        │\n      │ GET /orders/live    │ computed from list │\n      │ SSE stream          │ per-table dishes   │\n      └─────────────────────┴────────────────────┘\n  0c DECOMPOSE: 1 row per component (shared first, then page-specific)\n       spec_ref = 'Spec_9 §3.2'  (exact section)\n       draw_ref = 'wireframes/overview.md zone-B'  (exact zone)\n  0d ALIGN wireframe with user BEFORE writing any code\n\nTask NOT READY if: dep not ✅ · spec_ref missing (FE) · draw_ref missing (FE)","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"SPLIT SIGNAL — These always create a NEW task row:\n  Different business rule → different test case → different task\n    e.g. CreateOrder (BR-001 1-table-1-active) ≠ CancelOrder (BR-002 30% rule)\n  Different protocol → different implementation pattern → different task\n    e.g. SSE stream ≠ WebSocket hub (different connection lifecycle)\n  Mandatory side effect → must be verified alone → different task\n    e.g. KDS item update requires recalculateTotalAmount() + WS broadcast\n\nFE EXTRA GATE — Step 0 before any task rows:\n  0a READ SPEC end-to-end (mark screens, components, data sources)\n  0b DRAW Wireframe (label zones [ComponentName] + data source per zone)\n      ┌─────────────────────┬────────────────────┐\n      │ [OrderList]         │ [PrepPanel]        │\n      │ GET /orders/live    │ computed from list │\n      │ SSE stream          │ per-table dishes   │\n      └─────────────────────┴────────────────────┘\n  0c DECOMPOSE: 1 row per component (shared first, then page-specific)\n       spec_ref = 'Spec_9 §3.2'  (exact section)\n       draw_ref = 'wireframes/overview.md zone-B'  (exact zone)\n  0d ALIGN wireframe with user BEFORE writing any code\n\nTask NOT READY if: dep not ✅ · spec_ref missing (FE) · draw_ref missing (FE)","lineHeight":1.35,"autoResize":false},

    {"id":"task_e_r","type":"rectangle","x":3245,"y":699,"width":1460,"height":230,"angle":0,"strokeColor":"#ea580c","backgroundColor":"#fff7ed","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":46,"version":1,"versionNonce":46,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b7","link":null,"locked":false,"frameId":null},
    {"id":"task_e_t","type":"text","x":3260,"y":707,"width":1430,"height":214,"angle":0,"strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":47,"version":1,"versionNonce":47,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"b8","link":null,"locked":false,"frameId":null,"text":"REAL EXAMPLE — Spec_4 §5 → 7 task rows (NOT 1):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n4-1 BE  CreateOrder handler+service+validate (1-table-1-active + combo expand)  ← BR-001\n4-2 BE  GetOrders + GetOrderByID handler + repository queries\n4-3 BE  UpdateOrderStatus: state machine validation + PATCH handler\n4-4 BE  CancelOrder: 30% guard + soft delete + handler                           ← BR-002 (different rule)\n4-5 BE  KDS item cycle: PATCH item + recalculateTotalAmount + WS broadcast       ← mandatory side effect\n4-6 BE  SSE stream /orders/:id/sse: Redis pub/sub subscribe                      ← different protocol\n4-7 BE  WebSocket hub: /ws/kitchen + /ws/orders-live + broadcast logic           ← different protocol\n\nWhy NOT one task? Each can be built and tested independently. 4-4 has a unique business rule test.\n4-5 has a side effect that must be verified. 4-6 and 4-7 use different connection protocols.","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"REAL EXAMPLE — Spec_4 §5 → 7 task rows (NOT 1):\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n4-1 BE  CreateOrder handler+service+validate (1-table-1-active + combo expand)  ← BR-001\n4-2 BE  GetOrders + GetOrderByID handler + repository queries\n4-3 BE  UpdateOrderStatus: state machine validation + PATCH handler\n4-4 BE  CancelOrder: 30% guard + soft delete + handler                           ← BR-002 (different rule)\n4-5 BE  KDS item cycle: PATCH item + recalculateTotalAmount + WS broadcast       ← mandatory side effect\n4-6 BE  SSE stream /orders/:id/sse: Redis pub/sub subscribe                      ← different protocol\n4-7 BE  WebSocket hub: /ws/kitchen + /ws/orders-live + broadcast logic           ← different protocol\n\nWhy NOT one task? Each can be built and tested independently. 4-4 has a unique business rule test.\n4-5 has a side effect that must be verified. 4-6 and 4-7 use different connection protocols.","lineHeight":1.35,"autoResize":false},

