    {"id":"task_prin_t","type":"text","x":3260,"y":945,"width":1430,"height":102,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":49,"version":1,"versionNonce":49,"isDeleted":false,"boundElements":[],"updated":1746500000000,"index":"bA","link":null,"locked":false,"frameId":null,"text":"PRINCIPLE — BOUNDARY RULE:\nSplit when: different business rule · different protocol · mandatory side effect · FE = different component.\nDo NOT split by: file count, line count, or 'it feels big'.\nFE task with no spec_ref = cannot trace to a spec = do not start.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PRINCIPLE — BOUNDARY RULE:\nSplit when: different business rule · different protocol · mandatory side effect · FE = different component.\nDo NOT split by: file count, line count, or 'it feels big'.\nFE task with no spec_ref = cannot trace to a spec = do not start.","lineHeight":1.35,"autoResize":false},

