    {"id":"t1b_t","type":"text","x":975,"y":410,"width":950,"height":152,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1071,"version":2,"versionNonce":1071,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"aK","link":null,"locked":false,"frameId":null,"text":"docs/IMPLEMENTATION_WORKFLOW.md — 7-STEP QUALITY PROCESS\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nStep 1: READ — spec + system guide + contracts\nStep 2: PLAN — list subtasks, identify risks\nStep 3: ALIGN — confirm plan with user before coding\nStep 4: IMPLEMENT — write code following patterns\nStep 5: SELF-REVIEW — check AC, errors, patterns\nStep 6: TEST — run tests, start dev server, verify UI\nStep 7: DONE — update TASKS.md status to ✅\n\nFE Pre-Task (Step 0): Step 0a READ SPEC → 0b DRAW wireframe → 0c DECOMPOSE → 0d WRITE task rows\nRule: FE tasks MUST have spec_ref + draw_ref before starting","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/IMPLEMENTATION_WORKFLOW.md — 7-STEP QUALITY PROCESS\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nStep 1: READ — spec + system guide + contracts\nStep 2: PLAN — list subtasks, identify risks\nStep 3: ALIGN — confirm plan with user before coding\nStep 4: IMPLEMENT — write code following patterns\nStep 5: SELF-REVIEW — check AC, errors, patterns\nStep 6: TEST — run tests, start dev server, verify UI\nStep 7: DONE — update TASKS.md status to ✅\n\nFE Pre-Task (Step 0): Step 0a READ SPEC → 0b DRAW wireframe → 0c DECOMPOSE → 0d WRITE task rows\nRule: FE tasks MUST have spec_ref + draw_ref before starting","lineHeight":1.35,"autoResize":false},

