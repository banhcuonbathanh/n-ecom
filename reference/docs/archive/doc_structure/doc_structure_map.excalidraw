    {"id":"t1c_t","type":"text","x":2005,"y":410,"width":930,"height":152,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1081,"version":2,"versionNonce":1081,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"aM","link":null,"locked":false,"frameId":null,"text":"docs/base/LESSONS_LEARNED_v3.md — SESSION WORKFLOW GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nPrefix system detail:\n  💡 SUGGESTION — optional improvement idea\n  ⚠️ FLAG — something to watch, not blocking\n  🚨 RISK — high-risk action, explain before proceed\n  🔴 STOP — do not continue without confirmation\n  ❓ CLARIFY — ambiguous, ask before coding\n  🔄 REDIRECT — wrong direction, pivot now\n\nAlso stores: session patterns, lessons from past failures\nCommands: /handoff to close session","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/base/LESSONS_LEARNED_v3.md — SESSION WORKFLOW GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nPrefix system detail:\n  💡 SUGGESTION — optional improvement idea\n  ⚠️ FLAG — something to watch, not blocking\n  🚨 RISK — high-risk action, explain before proceed\n  🔴 STOP — do not continue without confirmation\n  ❓ CLARIFY — ambiguous, ask before coding\n  🔄 REDIRECT — wrong direction, pivot now\n\nAlso stores: session patterns, lessons from past failures\nCommands: /handoff to close session","lineHeight":1.35,"autoResize":false},

