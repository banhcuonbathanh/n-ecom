    {"id":"g2t","type":"text","x":1025,"y":950,"width":950,"height":264,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1191,"version":2,"versionNonce":1191,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"ag","link":null,"locked":false,"frameId":null,"text":"docs/fe/FE_SYSTEM_GUIDE.md — PRIMARY FE GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n8 Epics: Auth · Menu · Cart/Checkout · KDS · POS · Admin · Staff · Marketing\n\nKey rules:\n  ▸ Server state: TanStack Query v5 (useQuery / useMutation)\n  ▸ Client state: Zustand v4 (stores per domain)\n  ▸ Forms: React Hook Form + Zod validation\n  ▸ API calls: lib/api-client.ts ONLY\n  ▸ Design tokens from MASTER §2\n  ▸ TypeScript strict — no any, no ts-ignore\n  ▸ Next.js 14 App Router — server components default\n  ▸ Per-epic reading list at §8\n\nFE task format: spec_ref + draw_ref REQUIRED\nSupersedes: FE_DOC_INDEX.md","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/fe/FE_SYSTEM_GUIDE.md — PRIMARY FE GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n8 Epics: Auth · Menu · Cart/Checkout · KDS · POS · Admin · Staff · Marketing\n\nKey rules:\n  ▸ Server state: TanStack Query v5 (useQuery / useMutation)\n  ▸ Client state: Zustand v4 (stores per domain)\n  ▸ Forms: React Hook Form + Zod validation\n  ▸ API calls: lib/api-client.ts ONLY\n  ▸ Design tokens from MASTER §2\n  ▸ TypeScript strict — no any, no ts-ignore\n  ▸ Next.js 14 App Router — server components default\n  ▸ Per-epic reading list at §8\n\nFE task format: spec_ref + draw_ref REQUIRED\nSupersedes: FE_DOC_INDEX.md","lineHeight":1.35,"autoResize":false},

