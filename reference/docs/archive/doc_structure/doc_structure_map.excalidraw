    {"id":"g1t","type":"text","x":65,"y":950,"width":890,"height":264,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1181,"version":2,"versionNonce":1181,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"ae","link":null,"locked":false,"frameId":null,"text":"docs/be/BE_SYSTEM_GUIDE.md — PRIMARY BE GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n8 Epics: Auth · Products · Tables · Orders · Payments · KDS · QR · Staff\n\nKey rules:\n  ▸ Strict layers: Handler → Service → Repository → DB (sqlc)\n  ▸ DI pattern (deps injected in main.go)\n  ▸ Error codes come from ERROR_CONTRACT\n  ▸ Business rules from MASTER §4\n  ▸ JWT validation in middleware\n  ▸ Goose for migrations (be/migrations/)\n  ▸ Per-epic reading list at §8\n\nPrimary to read for:  CLAUDE_BE.md + Spec for that domain\nSupersedes: BE_DOC_INDEX.md","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/be/BE_SYSTEM_GUIDE.md — PRIMARY BE GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n8 Epics: Auth · Products · Tables · Orders · Payments · KDS · QR · Staff\n\nKey rules:\n  ▸ Strict layers: Handler → Service → Repository → DB (sqlc)\n  ▸ DI pattern (deps injected in main.go)\n  ▸ Error codes come from ERROR_CONTRACT\n  ▸ Business rules from MASTER §4\n  ▸ JWT validation in middleware\n  ▸ Goose for migrations (be/migrations/)\n  ▸ Per-epic reading list at §8\n\nPrimary to read for:  CLAUDE_BE.md + Spec for that domain\nSupersedes: BE_DOC_INDEX.md","lineHeight":1.35,"autoResize":false},

