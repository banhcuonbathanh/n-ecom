    {"id":"g3t","type":"text","x":2045,"y":950,"width":890,"height":264,"angle":0,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1201,"version":2,"versionNonce":1201,"isDeleted":false,"boundElements":[],"updated":1746316800000,"index":"ai","link":null,"locked":false,"frameId":null,"text":"docs/devops/DEVOPS_SYSTEM_GUIDE.md — PRIMARY DEVOPS GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nInfra: Docker Compose · Caddy reverse proxy · GitHub Actions\n\nKey commands:\n  ▸ docker compose up -d                       (full stack)\n  ▸ docker compose up -d --build be|fe         (after code change)\n  ▸ docker compose logs -f be\n  ▸ goose -dir be/migrations mysql \"$DB_DSN\" up\n  ▸ cd fe && npm run dev                        (:3000)\n\nPorts:\n  BE=8080 · FE=3000 · MySQL=3306\n  Redis=6379 · RedisInsight=8001 · Swagger=8090\n\nFiles: .env.example · migrate.sh · Caddyfile · docker-compose.yml\nCI/CD: .github/workflows/","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"docs/devops/DEVOPS_SYSTEM_GUIDE.md — PRIMARY DEVOPS GUIDE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nInfra: Docker Compose · Caddy reverse proxy · GitHub Actions\n\nKey commands:\n  ▸ docker compose up -d                       (full stack)\n  ▸ docker compose up -d --build be|fe         (after code change)\n  ▸ docker compose logs -f be\n  ▸ goose -dir be/migrations mysql \"$DB_DSN\" up\n  ▸ cd fe && npm run dev                        (:3000)\n\nPorts:\n  BE=8080 · FE=3000 · MySQL=3306\n  Redis=6379 · RedisInsight=8001 · Swagger=8090\n\nFiles: .env.example · migrate.sh · Caddyfile · docker-compose.yml\nCI/CD: .github/workflows/","lineHeight":1.35,"autoResize":false},

