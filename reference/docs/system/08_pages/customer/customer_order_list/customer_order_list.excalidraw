      "index": "z00037",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "• Ownership BY TABLE: role==customer → callerID swapped to claims.TableID; service 403s if order.table_id ≠ caller.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Ownership BY TABLE: role==customer → callerID swapped to claims.TableID; service 403s if order.table_id ≠ caller.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "p3-0039",
