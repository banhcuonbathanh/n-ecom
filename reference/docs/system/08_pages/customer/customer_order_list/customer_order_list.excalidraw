      "frameId": null,
      "text": "• Every overlay endpoint behind authMW; guest JWT (sub=\"guest\", role=\"customer\", table_id) satisfies all 4.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Every overlay endpoint behind authMW; guest JWT (sub=\"guest\", role=\"customer\", table_id) satisfies all 4.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "p3-0038",
