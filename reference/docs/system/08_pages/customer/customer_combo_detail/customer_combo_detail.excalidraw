      "updated": 1746316800000,
      "index": "z00009",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "['combos']        → rawCombos[]  (5-min staleTime)\n  one entry = { id, name, price,\n    combo_items:[{id,product_id,quantity}] }\n\n['products-all']  → products[]   (5-min staleTime)\n  → productMap: product_id → {name, price}\n\nthe combo memo (page.tsx:30-50) JOINs\nthe two into the enriched combo.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "['combos']        → rawCombos[]  (5-min staleTime)\n  one entry = { id, name, price,\n    combo_items:[{id,product_id,quantity}] }\n\n['products-all']  → products[]   (5-min staleTime)\n  → productMap: product_id → {name, price}\n\nthe combo memo (page.tsx:30-50) JOINs\nthe two into the enriched combo.",
      "autoResize": true,
      "lineHeight": 1.25
    },
