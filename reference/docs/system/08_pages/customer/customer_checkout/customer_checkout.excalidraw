      "frameId": null,
      "text": "PATCH /orders/A/items/X → qty_served++\n  ─Redis publish─▶\n  • /order/<id>  SSE item_progress → bar moves\n                 → ▓ order_cache_A written back\n  • /tracking    SSE items_* → refetch card\n  • admin floor  orders WS → ['orders','live']\n  • other guests /tracking → queue.update",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PATCH /orders/A/items/X → qty_served++\n  ─Redis publish─▶\n  • /order/<id>  SSE item_progress → bar moves\n                 → ▓ order_cache_A written back\n  • /tracking    SSE items_* → refetch card\n  • admin floor  orders WS → ['orders','live']\n  • other guests /tracking → queue.update",
      "autoResize": true,
      "lineHeight": 1.25
    },
