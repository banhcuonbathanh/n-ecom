    {
      "id": "p4-0005",
      "type": "text",
      "x": 1472,
      "y": 132,
      "width": 333,
      "height": 114,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "z00004",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "▓ order_cache_<id>  localStorage   \"what is order X?\"\n░ activeOrderId     cart store     → /checkout CLEARS to null\n▓ <id>              the URL         \"shareable / reloadable\"\n\n/checkout ─POST─▶ onSuccess:\n  ① try GET /orders/:id (may 403 online, Bug3)\n  ② order_cache_<id> = JSON  ③ clearCart()\n  router.replace ▶ /order/<id> ▶ /order list\n     └ \"Thêm món\" ▶ /menu?add_to_order=<id>\n     └ \"Theo dõi bàn\" ▶ /tracking (monitor SSE)",
      "fontSize": 9,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "▓ order_cache_<id>  localStorage   \"what is order X?\"\n░ activeOrderId     cart store     → /checkout CLEARS to null\n▓ <id>              the URL         \"shareable / reloadable\"\n\n/checkout ─POST─▶ onSuccess:\n  ① try GET /orders/:id (may 403 online, Bug3)\n  ② order_cache_<id> = JSON  ③ clearCart()\n  router.replace ▶ /order/<id> ▶ /order list\n     └ \"Thêm món\" ▶ /menu?add_to_order=<id>\n     └ \"Theo dõi bàn\" ▶ /tracking (monitor SSE)",
      "autoResize": true,
      "lineHeight": 1.25
    },
