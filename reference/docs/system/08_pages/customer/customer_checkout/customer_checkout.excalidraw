      "index": "z00007",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "FE onError waits for an error BE never sends. Busy table → 201 + table_busy:true\n+ parallel order created (deliberate rule, BUSINESS_RULES §2.3). ErrTableHasActiveOrder\n(errors.go:30) referenced nowhere. Checkout also ignores table_busy. Fix: FE.",
      "fontSize": 9,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FE onError waits for an error BE never sends. Busy table → 201 + table_busy:true\n+ parallel order created (deliberate rule, BUSINESS_RULES §2.3). ErrTableHasActiveOrder\n(errors.go:30) referenced nowhere. Checkout also ignores table_busy. Fix: FE.",
      "autoResize": true,
      "lineHeight": 1.25
    },
