      "link": null,
      "locked": false,
      "frameId": null,
      "text": "POST /orders → pending ─(staff confirm)→ confirmed ─(KDS)→ preparing ─(all served)→ ready ─(staff bill)→ delivered → paid\n              └────────────────────────── cancelled ◀─ (staff/guest cancel)     │  item-level: pending(0)→preparing(0<n<qty)→done(n≥qty)",
      "fontSize": 9,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST /orders → pending ─(staff confirm)→ confirmed ─(KDS)→ preparing ─(all served)→ ready ─(staff bill)→ delivered → paid\n              └────────────────────────── cancelled ◀─ (staff/guest cancel)     │  item-level: pending(0)→preparing(0<n<qty)→done(n≥qty)",
      "autoResize": true,
      "lineHeight": 1.25
    },
