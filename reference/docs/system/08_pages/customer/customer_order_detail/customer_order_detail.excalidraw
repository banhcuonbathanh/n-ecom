      "frameId": null,
      "text": "NO Redis read-cache on any endpoint — orders read live from MySQL. Redis is pub/sub fan-out only; publish failures logged + swallowed. Client staleness = localStorage order_cache_<id>.",
      "fontSize": 9,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NO Redis read-cache on any endpoint — orders read live from MySQL. Redis is pub/sub fan-out only; publish failures logged + swallowed. Client staleness = localStorage order_cache_<id>.",
      "autoResize": false,
      "lineHeight": 1.25
    },
