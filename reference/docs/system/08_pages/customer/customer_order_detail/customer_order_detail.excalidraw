      "updated": 1746316800000,
      "index": "z00017",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "StreamOrder only needs valid token via authMW — never checks order.table_id vs caller (sse/handler.go:21-70). Any authed client who knows an id can subscribe. REST paths DO enforce ownership.",
      "fontSize": 9,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "StreamOrder only needs valid token via authMW — never checks order.table_id vs caller (sse/handler.go:21-70). Any authed client who knows an id can subscribe. REST paths DO enforce ownership.",
      "autoResize": false,
      "lineHeight": 1.25
    },
