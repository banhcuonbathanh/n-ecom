      "link": null,
      "locked": false,
      "frameId": null,
      "text": "⚠ 4 · SSE handler has no ownership check",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "⚠ 4 · SSE handler has no ownership check",
