      "index": "e0001",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Same order, three representations: client cart (Zustand) → server cache (TanStack) → persisted Order (BE truth). Source: docs/system.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Same order, three representations: client cart (Zustand) → server cache (TanStack) → persisted Order (BE truth). Source: docs/system.",
      "autoResize": true,
      "lineHeight": 1.25
    },
