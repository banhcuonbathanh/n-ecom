      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0112",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "claims = { sub:'guest',\n  role:'customer',\n  table_id:'<uuid Bàn 01>' }\n→ callerID = \"\"  (guest)",
      "fontSize": 10,
      "fontFamily": 3,
