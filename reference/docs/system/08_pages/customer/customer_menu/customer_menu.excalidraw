      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Standalone item. GetProductSnapshot(product_id) → name + unit_price taken SERVER-side (client price discarded). buildToppingsSnapshot resolves topping ids → [{id,name,price}] JSON; unknown/unavailable toppings skipped. nhân rides here as a ₫0 topping (no 'filling' column).",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Standalone item. GetProductSnapshot(product_id) → name + unit_price taken SERVER-side (client price discarded). buildToppingsSnapshot resolves topping ids → [{id,name,price}] JSON; unknown/unavailable toppings skipped. nhân rides here as a ₫0 topping (no 'filling' column).",
      "autoResize": false,
      "lineHeight": 1.25
    },
