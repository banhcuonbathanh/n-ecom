      "index": "f0141",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Redis INCR order:seq:YYYYMMDD (per-day counter); on the first incr sets EXPIRE 25h. If Redis is down → timestamp fallback ORD-<date>-<ms%100000>. The repo retries ≤3× regenerating this on a uq_orders_order_number unique clash.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redis INCR order:seq:YYYYMMDD (per-day counter); on the first incr sets EXPIRE 25h. If Redis is down → timestamp fallback ORD-<date>-<ms%100000>. The repo retries ≤3× regenerating this on a uq_orders_order_number unique clash.",
      "autoResize": false,
      "lineHeight": 1.25
    },
