      "index": "f0080",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "setCanhQty(id, rau, 'rau', 1) — NOT addItem. Upsert by STABLE id 'canh_<id>_rau|plain'; qty 0 = remove. Price always 0. Stable id = same bowl never duplicates.",
      "fontSize": 9,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "setCanhQty(id, rau, 'rau', 1) — NOT addItem. Upsert by STABLE id 'canh_<id>_rau|plain'; qty 0 = remove. Price always 0. Stable id = same bowl never duplicates.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
