    {
      "id": "p11-0182",
      "type": "text",
      "x": 400,
      "y": 9020,
      "width": 830,
      "height": 27,
      "angle": 0,
      "strokeColor": "#d1fae5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0181",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "INSERT orders (status defaults 'pending', created_by NULL for guest). INSERT order_items × N (1 header + 2 combo children + 1 món lẻ + 1 canh). RecalculateTotalAmount UPDATEs the denormalized total from the rows — the header's unit_price 0 is naturally excluded by the SUM.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "INSERT orders (status defaults 'pending', created_by NULL for guest). INSERT order_items × N (1 header + 2 combo children + 1 món lẻ + 1 canh). RecalculateTotalAmount UPDATEs the denormalized total from the rows — the header's unit_price 0 is naturally excluded by the SUM.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "p11-0183",
      "type": "text",
      "x": 1246,
      "y": 9020,
      "width": 1252,
      "height": 77,
      "angle": 0,
      "strokeColor": "#86efac",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0182",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "UPDATE orders SET total_amount = (\n  SELECT COALESCE(\n    SUM(unit_price*quantity),0)\n  FROM order_items\n  WHERE order_id = orders.id)\n→ 0+21000+0+35000+0 = 56000",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UPDATE orders SET total_amount = (\n  SELECT COALESCE(\n    SUM(unit_price*quantity),0)\n  FROM order_items\n  WHERE order_id = orders.id)\n→ 0+21000+0+35000+0 = 56000",
      "autoResize": true,
      "lineHeight": 1.25
    },
