      "index": "f0099",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "ONE request, six layers. Client prices are never trusted — the service re-snapshots name + unit_price from the catalog; the whole insert is ONE atomic tx; the combo header's ₫0 is what keeps total_amount honest.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ONE request, six layers. Client prices are never trusted — the service re-snapshots name + unit_price from the catalog; the whole insert is ONE atomic tx; the combo header's ₫0 is what keeps total_amount honest.",
      "autoResize": true,
      "lineHeight": 1.25
    },
