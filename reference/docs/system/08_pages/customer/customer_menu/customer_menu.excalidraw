      "index": "a0044",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "POST /orders detail: validates source oneof + items min1 + product/combo XOR · snapshots name/unit_price/toppings_snapshot\nserver-side (client prices never trusted) · combo → header(unit_price=0)+sub-items(combo_ref_id) · table_busy:true is RESPONSE-ONLY\n(not on the order object) · order_number from Redis counter w/ order_sequences DB fallback. GET /orders/:id re-fetched & cached\nin localStorage ORDER_CACHE right after create.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST /orders detail: validates source oneof + items min1 + product/combo XOR · snapshots name/unit_price/toppings_snapshot\nserver-side (client prices never trusted) · combo → header(unit_price=0)+sub-items(combo_ref_id) · table_busy:true is RESPONSE-ONLY\n(not on the order object) · order_number from Redis counter w/ order_sequences DB fallback. GET /orders/:id re-fetched & cached\nin localStorage ORDER_CACHE right after create.",
      "lineHeight": 1.35,
      "autoResize": true
    },
