      "link": null,
      "locked": false,
      "frameId": null,
      "text": "items:[\n  { id:\"combo_<SuấtGiò>\", type:\"combo\", quantity:1,\n    price:21000,\n    toppings:[],                ← nhân not picked yet\n    combo_items:[ Giò×1, BánhCuốn×3, Canh×1 ] }  ← template\n]\ntotal() = 21000      itemCount() = 1",
