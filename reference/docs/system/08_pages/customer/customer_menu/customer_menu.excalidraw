      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0019",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Writes come later: POST /orders → invalidate ['orders'] (catalog GETs untouched).  1-char search disables the products query (no refetch, no skeleton).",
