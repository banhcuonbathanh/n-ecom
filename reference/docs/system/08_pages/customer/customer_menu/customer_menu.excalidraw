    {
      "id": "p1215-0187",
      "type": "text",
      "x": 54,
      "y": 10756,
      "width": 219,
      "height": 17,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
