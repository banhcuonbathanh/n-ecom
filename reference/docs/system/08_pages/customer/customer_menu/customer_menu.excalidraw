      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0172",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "tx := BeginTx(); defer Rollback()\nCreateOrder(...)\nfor row: CreateOrderItem(row)\nRecalculateTotalAmount(id)\ntx.Commit()",
