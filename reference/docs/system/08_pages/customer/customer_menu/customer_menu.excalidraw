      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0095",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "3 builder transforms (order-payload.ts):\n1 combo → header (product_id:null + combo_id) + overrides\n2 canh STRIPPED from combo_items (travels as own row;\n  BE treats supplied combo_items as the COMPLETE list)\n3 toppings flattened to ids (nhân on each non-canh child)",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3 builder transforms (order-payload.ts):\n1 combo → header (product_id:null + combo_id) + overrides\n2 canh STRIPPED from combo_items (travels as own row;\n  BE treats supplied combo_items as the COMPLETE list)\n3 toppings flattened to ids (nhân on each non-canh child)",
      "autoResize": true,
      "lineHeight": 1.25
    },
