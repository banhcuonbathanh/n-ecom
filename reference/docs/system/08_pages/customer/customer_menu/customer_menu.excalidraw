      "index": "f0018",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "['categories'] →[] no UI  ·  ['products-all'] →[] silent (combo enrich)  ·  ['combos'] →[] hidden until length>0  ·  ['products',cat,q] →[] ⏳ SKELETON 5 mobile / 8 desktop cards",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "['categories'] →[] no UI  ·  ['products-all'] →[] silent (combo enrich)  ·  ['combos'] →[] hidden until length>0  ·  ['products',cat,q] →[] ⏳ SKELETON 5 mobile / 8 desktop cards",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
