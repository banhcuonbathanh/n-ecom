      "verticalAlign": "top",
      "containerId": null,
      "originalText": "items:[ combo…,\n  { id:\"prod_<BánhCuốnThịt>\", type:\"product\", quantity:1,\n    price:35000,                          ← món lẻ has real price\n    toppings:[ {Nhân thịt, ₫0} ] }        ← NEW standalone line\n]\ntotal() = 56000      itemCount() = 2",
      "autoResize": true,
      "lineHeight": 1.25
    },
