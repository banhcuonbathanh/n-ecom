    {
      "id": "p11-0192",
      "type": "text",
      "x": 400,
      "y": 9144,
      "width": 830,
      "height": 27,
      "angle": 0,
      "strokeColor": "#d1fae5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
