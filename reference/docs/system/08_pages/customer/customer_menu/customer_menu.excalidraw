      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "g0118",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "PANEL 13 · Realtime fan-out — one POST commit lights up FOUR other screens (Redis pub/sub, decoupled)",
      "fontSize": 16,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PANEL 13 · Realtime fan-out — one POST commit lights up FOUR other screens (Redis pub/sub, decoupled)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "p1215-0120",
      "type": "text",
      "x": 40,
      "y": 10274,
      "width": 2476,
      "height": 15,
      "angle": 0,
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "g0119",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "After tx.Commit (Panel 11 B9) the service PUBLISHes to Redis; the guest already has their 201. Each channel has a BE SSE/WS subscriber that streams to a FE hook on a DIFFERENT page. The /menu page waits for none of this. Source: order_service.go publish* · be/internal/sse,websocket · fe/src/hooks.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "After tx.Commit (Panel 11 B9) the service PUBLISHes to Redis; the guest already has their 201. Each channel has a BE SSE/WS subscriber that streams to a FE hook on a DIFFERENT page. The /menu page waits for none of this. Source: order_service.go publish* · be/internal/sse,websocket · fe/src/hooks.",
      "autoResize": false,
      "lineHeight": 1.25
    },
