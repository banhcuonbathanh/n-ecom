      "link": null,
      "locked": false,
      "frameId": null,
      "text": "201 {data:{id, table_busy}}. FE then GET /orders/:id (authMW) for the full order and writes it to localStorage order_cache_<id>. table_busy is response-ONLY — never on the order object itself.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "201 {data:{id, table_busy}}. FE then GET /orders/:id (authMW) for the full order and writes it to localStorage order_cache_<id>. table_busy is response-ONLY — never on the order object itself.",
      "autoResize": false,
      "lineHeight": 1.25
    },
