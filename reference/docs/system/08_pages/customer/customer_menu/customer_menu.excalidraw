      "boundElements": [],
      "updated": 1746316800000,
      "index": "f0083",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "NO BE call. The gate is an ID-CONVENTION rule, not a\ntype field: renaming 'canh_' breaks the gate silently.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NO BE call. The gate is an ID-CONVENTION rule, not a\ntype field: renaming 'canh_' breaks the gate silently.",
      "autoResize": true,
      "lineHeight": 1.25
    },
