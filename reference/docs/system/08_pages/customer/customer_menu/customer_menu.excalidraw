      "index": "e0006",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "useCartStore  (Zustand + persist)\n  items: CartItem[]            // session-only · NOT persisted\n  tableId / tableName: string | null\n  activeOrderId: string | null      <-- persisted\n  paymentMethod: string | null\n  orderNote: string                 <-- persisted\n  -- selectors (derived from items) --\n  total()     = Σ price × quantity\n  itemCount() = Σ quantity\n  persist key 'cart-config-v3' · partialize {orderNote, activeOrderId}\nCartItem { id, type:'combo'|'product', quantity, price,\n           toppings?[], combo_items?[] }",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "useCartStore  (Zustand + persist)\n  items: CartItem[]            // session-only · NOT persisted\n  tableId / tableName: string | null\n  activeOrderId: string | null      <-- persisted\n  paymentMethod: string | null\n  orderNote: string                 <-- persisted\n  -- selectors (derived from items) --\n  total()     = Σ price × quantity\n  itemCount() = Σ quantity\n  persist key 'cart-config-v3' · partialize {orderNote, activeOrderId}\nCartItem { id, type:'combo'|'product', quantity, price,\n           toppings?[], combo_items?[] }",
      "autoResize": true,
      "lineHeight": 1.25
    },
