      "index": "f0131",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Defense-in-depth: items≥1 else 400 (never persist an empty order). GetActiveOrderByTable(table) → sets tableBusy flag (informational only — order still created). newUUID() for the order id, then builds the rows (combo expand vs product row) BEFORE opening the tx.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Defense-in-depth: items≥1 else 400 (never persist an empty order). GetActiveOrderByTable(table) → sets tableBusy flag (informational only — order still created). newUUID() for the order id, then builds the rows (combo expand vs product row) BEFORE opening the tx.",
      "autoResize": false,
      "lineHeight": 1.25
    },
