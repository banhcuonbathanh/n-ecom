      "index": "c000g6",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "Slide-in drawer. addToOrderId → button 'Thêm vào đơn hàng' (POST /orders/:id/items) +\nclearCart + push('/order/:id'). Else 'Thanh toán' → tableId ? TableConfirmModal : /checkout.\n[Xem đơn hàng] shows only when activeOrderId set. Combos collapse/expand to ×N dish list.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Slide-in drawer. addToOrderId → button 'Thêm vào đơn hàng' (POST /orders/:id/items) +\nclearCart + push('/order/:id'). Else 'Thanh toán' → tableId ? TableConfirmModal : /checkout.\n[Xem đơn hàng] shows only when activeOrderId set. Combos collapse/expand to ×N dish list.",
      "lineHeight": 1.25,
      "autoResize": true
    },
