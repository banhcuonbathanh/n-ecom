    {
      "id": "t101025",
      "type": "text",
      "x": 1238,
      "y": 346,
      "width": 644,
      "height": 29,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
