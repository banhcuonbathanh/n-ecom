      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "a004y",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "one order row · order.id · status  (MySQL durable + Redis pub/sub)\ncustomer side: GET /orders/:id · SSE /orders/:id/events · SSE /sse/order-monitor/:id\nstaff/admin side: /sse/admin new_order ping · orders WS item_progress/status · GET /orders/:id → ['orders','live']\nadmin shares NO browser state w/ customer — only order.id; each side keeps its own copy fresh from its own channel.\nINVARIANT: no arrow phone→phone or phone→admin. Always device → BE → (Redis) → device.",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "one order row · order.id · status  (MySQL durable + Redis pub/sub)\ncustomer side: GET /orders/:id · SSE /orders/:id/events · SSE /sse/order-monitor/:id\nstaff/admin side: /sse/admin new_order ping · orders WS item_progress/status · GET /orders/:id → ['orders','live']\nadmin shares NO browser state w/ customer — only order.id; each side keeps its own copy fresh from its own channel.\nINVARIANT: no arrow phone→phone or phone→admin. Always device → BE → (Redis) → device.",
      "lineHeight": 1.35,
      "autoResize": true
    },
