    {
      "id": "t101627",
      "type": "text",
      "x": 1818,
      "y": 1645,
      "width": 664,
      "height": 69,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
