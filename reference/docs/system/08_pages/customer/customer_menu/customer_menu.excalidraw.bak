      "index": "a0051",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "pending →(staff confirm)→ confirmed →(KDS)→ preparing →(all served)→ ready →(handed over)→ delivered →(payment)→ paid\n            └──────── cancelled ◀ (staff/guest cancel, any active state) ·  item-level: qty_served 0=pending / 0<n<qty=preparing / n≥qty=done\nadmin ACTIVE set = {pending,confirmed,preparing,ready,delivered} — leaving it drops the card · customer useOrderSSE STOPS on cancelled/delivered\ncustomer sees: pending'chờ xác nhận' confirmed'+ETA' preparing'bar fills' ready'sẵn sàng' · cancelled & paid → filtered from live floor",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pending →(staff confirm)→ confirmed →(KDS)→ preparing →(all served)→ ready →(handed over)→ delivered →(payment)→ paid\n            └──────── cancelled ◀ (staff/guest cancel, any active state) ·  item-level: qty_served 0=pending / 0<n<qty=preparing / n≥qty=done\nadmin ACTIVE set = {pending,confirmed,preparing,ready,delivered} — leaving it drops the card · customer useOrderSSE STOPS on cancelled/delivered\ncustomer sees: pending'chờ xác nhận' confirmed'+ETA' preparing'bar fills' ready'sẵn sàng' · cancelled & paid → filtered from live floor",
      "lineHeight": 1.35,
      "autoResize": true
    },
