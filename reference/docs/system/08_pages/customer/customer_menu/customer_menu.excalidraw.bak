      "index": "a005g",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "endpoint: PATCH /orders/:id/status {status:'cancelled'}\nFE gate: status∈{confirmed,preparing,ready} (admin CAN cancel ready)\nafter: optimistic ['orders','live'] then WS confirms → CancelLog\nguest (passively watching) sees via SSE order_cancelled:\n  setOrder(cancelled) · notification · SSE STOPS · ▓cache written\n  MODAL 'Nhà hàng đã huỷ đơn của bạn. Vui lòng liên hệ nhân viên.'\nboth verbs land status=cancelled + publish SAME order_cancelled\n  to order:{id}+orders:kds → identical fan-out",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "endpoint: PATCH /orders/:id/status {status:'cancelled'}\nFE gate: status∈{confirmed,preparing,ready} (admin CAN cancel ready)\nafter: optimistic ['orders','live'] then WS confirms → CancelLog\nguest (passively watching) sees via SSE order_cancelled:\n  setOrder(cancelled) · notification · SSE STOPS · ▓cache written\n  MODAL 'Nhà hàng đã huỷ đơn của bạn. Vui lòng liên hệ nhân viên.'\nboth verbs land status=cancelled + publish SAME order_cancelled\n  to order:{id}+orders:kds → identical fan-out",
      "lineHeight": 1.35,
      "autoResize": true
    },
