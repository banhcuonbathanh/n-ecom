    {
      "id": "p6-0018",
      "type": "text",
      "x": 1910,
      "y": 1526,
      "width": 625,
      "height": 103,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
