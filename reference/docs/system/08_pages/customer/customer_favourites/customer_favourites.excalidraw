      "seed": 1,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "z00019",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "store                 │ persist key                  │ persisted across sessions?            │ role here\nuseFavouritesStore    │ 'favourites'                 │ YES — whole {items,sets} tree         │ own data (written upstream on /menu)\nuseCartStore          │ 'cart-config-v3'             │ config YES · items[] NO (session-only)│ hand-off target (this page pushes in)\n⇒ a saved favourite/set survives a browser restart; the cart it fills does NOT — re-applying a set after restart is expected",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "store                 │ persist key                  │ persisted across sessions?            │ role here\nuseFavouritesStore    │ 'favourites'                 │ YES — whole {items,sets} tree         │ own data (written upstream on /menu)\nuseCartStore          │ 'cart-config-v3'             │ config YES · items[] NO (session-only)│ hand-off target (this page pushes in)\n⇒ a saved favourite/set survives a browser restart; the cart it fills does NOT — re-applying a set after restart is expected",
      "autoResize": true,
      "lineHeight": 1.25
    },
