      "isDeleted": false,
      "boundElements": [],
      "updated": 1746316800000,
      "index": "z00017",
      "link": null,
      "locked": false,
      "frameId": null,
      "text": "phase                         │ /favourites          │ /save                  │ /sets\nnav in progress               │ orange spinner       │ orange spinner         │ orange spinner\nmounted, queries in flight    │ EmptyState \"Nhấn ♥\"  │ summary empty, input ok│ SetCard empty-resolved / EmptyState\nresolved, items present       │ FilterTabs + cards   │ SummaryList populated  │ SetCard populated\nresolved, no items            │ EmptyState \"Nhấn ♥\"  │ summary empty          │ \"Chưa có set nào\"\nfetch error (either query)    │ EmptyState — same    │ summary empty          │ resolved empty — no error\nrevisit <5min of menu visit   │ items appear instant │ instant                │ instant (cache hit)\n\ngates: save/sets gate on STORE (sets.length / RHF isValid), NOT query state — empty set saveable mid-load",
      "fontSize": 9,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "phase                         │ /favourites          │ /save                  │ /sets\nnav in progress               │ orange spinner       │ orange spinner         │ orange spinner\nmounted, queries in flight    │ EmptyState \"Nhấn ♥\"  │ summary empty, input ok│ SetCard empty-resolved / EmptyState\nresolved, items present       │ FilterTabs + cards   │ SummaryList populated  │ SetCard populated\nresolved, no items            │ EmptyState \"Nhấn ♥\"  │ summary empty          │ \"Chưa có set nào\"\nfetch error (either query)    │ EmptyState — same    │ summary empty          │ resolved empty — no error\nrevisit <5min of menu visit   │ items appear instant │ instant                │ instant (cache hit)\n\ngates: save/sets gate on STORE (sets.length / RHF isValid), NOT query state — empty set saveable mid-load",
      "autoResize": true,
      "lineHeight": 1.25
    },
