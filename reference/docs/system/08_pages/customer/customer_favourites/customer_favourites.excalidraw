    {
      "id": "p6-0014",
      "type": "text",
      "x": 1910,
      "y": 1396,
      "width": 658,
      "height": 52,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
