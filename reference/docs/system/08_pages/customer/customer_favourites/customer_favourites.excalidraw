      "locked": false,
      "frameId": null,
      "text": "['products-all']  GET /products  staleTime 5min   ·   ['combos']  GET /combos  staleTime 5min   (same keys as /menu → cache hit, no RTT)\nresolve step (page.tsx:52-85):  items[] IDs  ⨝  catalog  →  FavouriteItemResolved[]   ·   filteredItems = activeTab gate (page-local useState)   ·   counts = derived from resolvedItems",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "['products-all']  GET /products  staleTime 5min   ·   ['combos']  GET /combos  staleTime 5min   (same keys as /menu → cache hit, no RTT)\nresolve step (page.tsx:52-85):  items[] IDs  ⨝  catalog  →  FavouriteItemResolved[]   ·   filteredItems = activeTab gate (page-local useState)   ·   counts = derived from resolvedItems",
      "autoResize": true,
      "lineHeight": 1.25
