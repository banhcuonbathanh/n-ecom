    {
      "id": "p5-0020",
      "type": "text",
      "x": 50,
      "y": 2644,
      "width": 796,
      "height": 52,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
