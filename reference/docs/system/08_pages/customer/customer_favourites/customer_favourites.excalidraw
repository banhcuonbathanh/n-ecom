      "frameId": null,
      "text": "TTL = productCacheTTL 5min\nkeys: products:list · combos:list\npage NEVER writes → never invalidates\ninvalidation only via staff mutation\nRedis fail-open → MySQL fallback\nsuite survives a Redis outage",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TTL = productCacheTTL 5min\nkeys: products:list · combos:list\npage NEVER writes → never invalidates\ninvalidation only via staff mutation\nRedis fail-open → MySQL fallback\nsuite survives a Redis outage",
      "autoResize": true,
      "lineHeight": 1.25
    },
