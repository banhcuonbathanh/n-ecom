      "link": null,
      "locked": false,
      "frameId": null,
      "text": "handler orderH.Get → svc.GetOrder → GetOrderByID + GetOrderItemsByOrderID + GetTableByID\nOWNERSHIP guard: customer callerID = claims.TableID; order.table_id ≠ caller → ErrForbidden (403)\nderived ItemStatus = itemStatus(qty_served, quantity)  (no order_items.status column)\nRedis: — none (hits MySQL every call · FE staleTime:0 · refetch on itemsChangedAt)",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "handler orderH.Get → svc.GetOrder → GetOrderByID + GetOrderItemsByOrderID + GetTableByID\nOWNERSHIP guard: customer callerID = claims.TableID; order.table_id ≠ caller → ErrForbidden (403)\nderived ItemStatus = itemStatus(qty_served, quantity)  (no order_items.status column)\nRedis: — none (hits MySQL every call · FE staleTime:0 · refetch on itemsChangedAt)",
      "autoResize": true,
      "lineHeight": 1.25
    },
