      "text": "data: {\n  date_range: { from, to }          ← ONLY place params land (echoed, never used to filter) mh.go:58\n  summary:    { total_budget, total_spent, total_remaining, spent_pct, roi, roi_base }   mh.go:59-66\n  items[5]:   { id, icon, name, sub_items[], budget, spent, remaining, progress_pct, color }  mh.go:23-54\n  love_score: { cost_per_new_customer, target/current_customers, target/current_followers,\n                follower_progress_pct, satisfaction_score, satisfaction_max }   mh.go:68-77\n}",
