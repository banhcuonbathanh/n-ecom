      "frameId": null,
      "text": "['admin','summary','week'] →\n  {customers:86, dishes_sold:240,\n   revenue:'4250000', active_tables:3}\n['admin','top-dishes','week'] →\n  [{name:'Bánh cuốn thịt', qty:820,\n    revenue:8200000, pct:82.0}, ...]\n['admin','low-stock'] →  (camelCase)\n  [{id, name:'Mộc nhĩ', unit:'kg',\n    quantity:0.2, warningThreshold:1,\n    status:'low_stock'}]",
      "fontSize": 11,
      "fontFamily": 3,
