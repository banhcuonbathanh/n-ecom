      "locked": false,
      "frameId": null,
      "text": "orders         status!='cancelled' + date\n               status IN(confirmed,prep,ready)\norder_items ⋈ orders status IN(deliv,paid)\n               combo_ref_id IS NULL (top-dish)\npayments       status='completed' (revenue)\nstaff LEFT JOIN orders/payments\n  WHERE is_active=1 AND role!='customer'\n-- repo:63-201 · raw SQL, no sqlc",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "orders         status!='cancelled' + date\n               status IN(confirmed,prep,ready)\norder_items ⋈ orders status IN(deliv,paid)\n               combo_ref_id IS NULL (top-dish)\npayments       status='completed' (revenue)\nstaff LEFT JOIN orders/payments\n  WHERE is_active=1 AND role!='customer'\n-- repo:63-201 · raw SQL, no sqlc",
      "autoResize": true,
      "lineHeight": 1.25
