      "frameId": null,
      "text": "UPDATE ingredients\nSET current_stock =\n  current_stock + 2      -- 'in'/'adjust' ADD\n  (out → GREATEST(0, stock-qty))\nWHERE id = '<uuid Mộc nhĩ>'\n-- 0.2 → 2.2 kg · repo:235-238\n-- ⚠ INSERT+UPDATE NOT in one tx",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UPDATE ingredients\nSET current_stock =\n  current_stock + 2      -- 'in'/'adjust' ADD\n  (out → GREATEST(0, stock-qty))\nWHERE id = '<uuid Mộc nhĩ>'\n-- 0.2 → 2.2 kg · repo:235-238\n-- ⚠ INSERT+UPDATE NOT in one tx",
      "autoResize": true,
      "lineHeight": 1.25
