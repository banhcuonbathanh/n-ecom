      "frameId": null,
      "text": "INSERT payments(order_id, method='cash', amount=order.total_amount, status='pending')\n→ completePayment: status='completed', paid_at=NOW()\n→ MarkOrderPaid: UPDATE orders SET status='paid'  (requires delivered)\n→ publish payment_success → orders:kds",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "INSERT payments(order_id, method='cash', amount=order.total_amount, status='pending')\n→ completePayment: status='completed', paid_at=NOW()\n→ MarkOrderPaid: UPDATE orders SET status='paid'  (requires delivered)\n→ publish payment_success → orders:kds",
      "autoResize": true,
      "lineHeight": 1.25
    },
