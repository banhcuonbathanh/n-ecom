      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "handleAction writes new status before PATCH resolves; on 409/error shows toast but does NOT revert. WS reconcile or 15s staleTime refetch heals — UI transiently wrong.",
      "autoResize": false,
      "lineHeight": 1.25
