      "locked": false,
      "frameId": null,
      "text": "per item:  qty_served vs quantity →\n  qty_served == 0           → 'pending'\n  0 < qty_served < quantity → 'preparing'\n  qty_served == quantity    → 'done'\nNOT a stored column · computed in GetOrder service",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "per item:  qty_served vs quantity →\n  qty_served == 0           → 'pending'\n  0 < qty_served < quantity → 'preparing'\n  qty_served == quantity    → 'done'\nNOT a stored column · computed in GetOrder service",
      "autoResize": true,
      "lineHeight": 1.25
    },
