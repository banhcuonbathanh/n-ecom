      "frameId": null,
      "text": "submit → POST /admin/tasks → onSuccess(task):\n  qc.invalidateQueries(['admin','tasks','stats', task.dueDate])   ◀── KEY\n  qc.invalidateQueries(['admin','tasks', task.staffId, task.dueDate]) ◀── KEY\n  toast.success · onSuccess()=no-op · onClose() → unmount",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "submit → POST /admin/tasks → onSuccess(task):\n  qc.invalidateQueries(['admin','tasks','stats', task.dueDate])   ◀── KEY\n  qc.invalidateQueries(['admin','tasks', task.staffId, task.dueDate]) ◀── KEY\n  toast.success · onSuccess()=no-op · onClose() → unmount",
      "autoResize": true,
      "lineHeight": 1.25
    },
